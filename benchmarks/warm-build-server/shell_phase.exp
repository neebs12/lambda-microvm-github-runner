#!/usr/bin/expect -f

set timeout 60
match_max 2000000
log_user 0

set endpoint $env(MICROVM_SHELL_ENDPOINT)
set token $env(MICROVM_SHELL_TOKEN)
set operation $env(BENCHMARK_OPERATION)
set server_id $env(BENCHMARK_SERVER_ID)
set payload $env(BENCHMARK_GUEST_SCRIPT_B64)
set job_kind $env(BENCHMARK_JOB_KIND)
set cycle $env(BENCHMARK_CYCLE)
set result_s3_uri $env(BENCHMARK_RESULT_S3_URI)

set header_argument "--header=X-aws-proxy-auth: $token"
spawn websocat --binary $header_argument "wss://$endpoint"
expect {
    -re {"type":"session_init"} {}
    timeout { exit 10 }
    eof { exit 11 }
}
send -- "\r"
expect {
    -re {λ \$ $} {}
    timeout { exit 10 }
    eof { exit 11 }
}
if {[info exists env(BENCHMARK_DEBUG)] && $env(BENCHMARK_DEBUG) eq "1"} {
    log_user 1
}

proc upload_guest {payload} {
    send -- ": > /tmp/lmvm-exact-job-benchmark.b64\r"
    expect -re {λ \$ $}
    set payload_length [string length $payload]
    for {set offset 0} {$offset < $payload_length} {incr offset 512} {
        set chunk [string range $payload $offset [expr {$offset + 511}]]
        send -- "printf '%s' '$chunk' >> /tmp/lmvm-exact-job-benchmark.b64\r"
        expect -re {λ \$ $}
    }
    send -- "base64 -d /tmp/lmvm-exact-job-benchmark.b64 > /tmp/lmvm-exact-job-benchmark.py\r"
    expect -re {λ \$ $}
}

set prefix "/tmp/lmvm-exact-job-$cycle"
if {$operation eq "job-start"} {
    upload_guest $payload
    send -- "if test -f $prefix.status || (test -f $prefix.pid && kill -0 \"\$(cat $prefix.pid)\" 2>/dev/null); then true; else rm -f $prefix.status; nohup sh -c 'python3 /tmp/lmvm-exact-job-benchmark.py job --server-id \"$server_id\" --kind \"$job_kind\" --cycle \"$cycle\" --result-s3-uri \"$result_s3_uri\" > $prefix.log 2>&1; echo \$? > $prefix.status' </dev/null >$prefix.launcher.log 2>&1 & echo \$! > $prefix.pid; fi\r"
    expect -re {λ \$ $}
    send -- "exit\r"
    expect eof
    puts "started"
} elseif {$operation eq "job-status"} {
    send -- "if test -f $prefix.status; then echo BENCHMARK_STATUS=\$(cat $prefix.status); elif test -f $prefix.pid && kill -0 \"\$(cat $prefix.pid)\" 2>/dev/null; then echo BENCHMARK_\"\"PENDING; else echo BENCHMARK_\"\"MISSING; fi\r"
    expect {
        -re {BENCHMARK_STATUS=0} { puts "complete" }
        -re {BENCHMARK_STATUS=([1-9][0-9]*)} {
            log_user 1
            send -- "tail -120 $prefix.log\r"
            expect -re {λ \$ $}
            exit 12
        }
        -re {BENCHMARK_PENDING} { puts "pending" }
        -re {BENCHMARK_MISSING} { exit 20 }
        timeout { exit 13 }
        eof { exit 14 }
    }
    send -- "exit\r"
    expect eof
} elseif {$operation eq "result"} {
    upload_guest $payload
    send -- "if python3 /tmp/lmvm-exact-job-benchmark.py diagnostic --result-s3-uri \"$result_s3_uri\"; then echo BENCHMARK_DIAGNOSTIC_OK; else echo BENCHMARK_DIAGNOSTIC_FAILED; fi\r"
    expect {
        -re {BENCHMARK_DIAGNOSTIC_OK} {}
        -re {BENCHMARK_DIAGNOSTIC_FAILED} { exit 15 }
        timeout { exit 15 }
        eof { exit 16 }
    }
    expect -re {λ \$ $}
    send -- "exit\r"
    expect eof
    puts "complete"
} else {
    exit 21
}
